# 1. Defina o ID do seu projeto (Substitua "SEU_PROJECT_ID" pelo seu ID real)
PROJECT_ID="SEU_PROJECT_ID" 

# 2. Defina o nome da imagem no Artifact Registry/Container Registry
# O formato gcr.io é a maneira padrão de referenciar o repositório do Google Cloud.
IMAGE_NAME="gcr.io/${PROJECT_ID}/extrator-magazord-job" 

# 3. O Comando de Submissão em si:
# - 'gcloud builds submit': Inicia o processo de construção na nuvem.
# - '.': O ponto indica "todos os arquivos no diretório atual".
# - '--tag ${IMAGE_NAME}': Atribui o nome e o destino da imagem construída.
gcloud builds submit --tag ${IMAGE_NAME} .


source .venv312/bin/activate


